    "@angular/router": "^20.3.16",
    "@bugsnag/angular-performance": "^3.0.0",
    "@bugsnag/browser-performance": "^3.4.1",
    "@bugsnag/js": "^8.8.1",
    "@bugsnag/plugin-angular": "^8.8.1",
    "@elastic/apm-rum-angular": "^3.0.9",
