{
  "name": "asistent",
  "version": "3.55.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start-localize": "ng serve --configuration=en",
    "build": "ng build --configuration production",
    "build-localize": "ng build --configuration production --localize",
    "start-ssl": "ng serve --ssl --ssl-key --ssl-cert",
    "lint": "ng lint --quiet",
    "lint-ci": "prettier --check . & ng lint",
    "prettier-check": "npx prettier --check .",
    "prettier-write": "npx prettier --write .",
    "test": "jest --config jest-angular-config.js --runInBand",
    "e2e": "jest --config jest-puppeteer-e2e-ui-config.js --runInBand",
    "e2e-docker": "npm run docker-build && npm run e2e-docker-fast",
    "e2e-docker-fast": "npm run docker-up && npm run e2e & npm run docker-down",
    "bundle-size": "ng build --stats-json",
    "analize-bundle-size": "webpack-bundle-analyzer ./dist/network/stats.json",
    "check-circular-deps": "npx madge src --circular --extensions ts --ts-config ./tsconfig.json",
    "check-unused": "npx ngx-unused .\\ -p .\\tsconfig.app.json",
    "check-unused-packages": "npx depcheck",
    "i18n:extract": "ng extract-i18n",
    "jenkins-build": "npm run build",
    "jenkins-install": "npm install --registry=https://registry.npmjs.org/ --legacy-peer-deps",
    "jenkins-upload-source-files": "node node_modules/@meddev/fe-shared/bin/utils/upload-source-maps.js",
    "prepare": "husky install || true"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.16",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.16",
